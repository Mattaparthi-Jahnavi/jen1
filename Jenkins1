pipeline {
    agent any

    environment {
        APP_NAME = "my-app"
        DOCKER_IMAGE = "my-app:latest"
    }

    stages {


        stage('Build') {
            steps {
                echo "Building application..."
                
            }
        }

        stage('Test') {
            steps {
                echo "Running tests..."
                
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building Docker image..."
                
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying application..."
                
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline executed successfully!"
        }
        failure {
            echo "❌ Pipeline failed!"
        }
    }
}